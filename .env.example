# QQ邮箱地址（发件用）
EMAIL_ADDRESS=your_email@qq.com

# QQ邮箱 SMTP 授权码（不是QQ密码！）
# 获取方式：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 开启 → 生成授权码
EMAIL_PASSWORD=your_authorization_code_here

# 接收邮件的邮箱（可以和发件邮箱相同）
RECIPIENT_EMAIL=receive@qq.com

# 可选配置
# MAX_ARTICLES_PER_SOURCE=8     # 每个信源最多取几篇
# CACHE_TTL_HOURS=24            # 去重窗口（小时）
